<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OTDR.Views.About.AboutWindow"
        Title="About OTDR App"
        Width="400"
        Height="350"
        MinHeight="350"
        MinWidth="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20"
          RowDefinitions="Auto,Auto,Auto">

        <TextBlock Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="400">
            <Run Text="Made by Krzysztof Paryż &amp; Kamil Skałka"/>
            <LineBreak/>
            <Run Text="AGH UST 2026/27"/>
        </TextBlock>

        <Panel Grid.Row="1" Margin="0,20,0,0">
            <Rectangle Height="200" Width="180" Fill="White"/>
            <Image Height="200" ClipToBounds="True" Source="avares://otdr/Views/About/Assets/agh_logo.png"/>
        </Panel>

        <Button Grid.Row="2"
                Content="Close"
                Click="OnCloseClick"
                HorizontalAlignment="Center"
                Margin="0,20,0,0"/>
    </Grid>

</Window>