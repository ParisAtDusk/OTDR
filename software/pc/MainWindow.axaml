<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OTDR.MainWindow"
        Title="OTDR"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500">
    
    <!-- TOP-LEVEL LAYOUT: a DockPanel so the menu bar is pinned to the
         top and everything else fills the remaining space. -->
    <DockPanel>
        <!-- 1) TOP BAR: a small always-visible toggle button (to show/hide
             the settings column even after it's collapsed) docked next to
             the typical "File / Settings / Help" style menu. -->
        <DockPanel DockPanel.Dock="Top">
            <ToggleButton x:Name="SettingsToggleButton"
                          DockPanel.Dock="Left"
                          Content="◀"
                          Width="32"
                          Margin="4,4,0,4"
                          IsChecked="True"
                          Click="OnToggleSettingsClick"
                          ToolTip.Tip="Show/hide settings panel"/>

            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="_New" Click="OnNewClick" InputGesture="Ctrl+N"/>
                    <MenuItem Header="_Open..." Click="OnOpenClick" InputGesture="Ctrl+O"/>
                    <Separator/>
                    <MenuItem Header="_Save" Click="OnSaveClick" InputGesture="Ctrl+S"/>
                    <MenuItem Header="Save _As..." Click="OnSaveAsClick"/>
                    <Separator/>
                    <MenuItem Header="E_xit" Click="OnExitClick"/>
                </MenuItem>

                <MenuItem Header="_Edit">
                    <MenuItem Header="_Undo" InputGesture="Ctrl+Z"/>
                    <MenuItem Header="_Redo" InputGesture="Ctrl+Y"/>
                    <Separator/>
                    <MenuItem Header="Cu_t" InputGesture="Ctrl+X"/>
                    <MenuItem Header="_Copy" InputGesture="Ctrl+C"/>
                    <MenuItem Header="_Paste" InputGesture="Ctrl+V"/>
                </MenuItem>

                <MenuItem Header="_View">
                    <MenuItem Header="Toggle _Settings Panel" Click="OnToggleSettingsClick"/>
                </MenuItem>

                <MenuItem Header="_Settings">
                    <MenuItem Header="_Preferences..." Click="OnPreferencesClick"/>
                    <MenuItem x:Name="ThemeMenuItem" Header="_Theme">
                        <MenuItem Header="Dark"  Click="OnThemeClick"/>
                        <MenuItem Header="Light" Click="OnThemeClick"/>
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="_Help">
                    <MenuItem Header="_Documentation" Click="OnDocsClick"/>
                    <MenuItem Header="_About" Click="OnAboutClick"/>
                </MenuItem>
            </Menu>
        </DockPanel>

        <!-- 2) MAIN CONTENT: a Grid with two columns.
             Left = settings column (fixed-ish width, scrollable)
             Right = main "frame" containing the chart
             A GridSplitter lets the user resize the panels. -->
        <Grid x:Name="RootGrid" ColumnDefinitions="280, 4, *">

            <!-- LEFT COLUMN: settings panel.
                 Wrapped in a ScrollViewer in case content overflows.
                 Contains THREE sections, each demonstrating a different
                 Avalonia layout panel, so you can refer back to them:
                   a) StackPanel   > simple vertical list (checkboxes)
                   b) Grid         > aligned label/control rows (sliders)
                   c) WrapPanel    > flowing buttons that wrap to a new line -->
            <ScrollViewer x:Name="SettingsPanel" Grid.Column="0" Padding="10">
                <StackPanel Spacing="14">

                    <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>

                    <!-- (a) StackPanel layout example.
                         StackPanel arranges children in a single line
                         (vertical here via default Orientation).
                         Good for simple, uniform lists like checkboxes. -->
                    <Expander Header="Display Options (StackPanel)" IsExpanded="True">
                        <StackPanel Spacing="8" Margin="4">
                            <CheckBox x:Name="ShowGridCheckBox" Content="Show grid lines" IsChecked="True" Click="OnShowGridChanged"/>
                            <CheckBox x:Name="ShowLegendCheckBox" Content="Show legend" IsChecked="True" Click="OnShowLegendChanged"/>
                            <CheckBox x:Name="ShowMarkersCheckBox" Content="Show markers" IsChecked="False" Click="OnShowMarkersChanged"/>
                            <CheckBox x:Name="AutoScaleCheckBox" Content="Auto-scale axes" IsChecked="True"/>
                        </StackPanel>
                    </Expander>

                    <!-- (b) Grid layout example.
                         Grid with explicit Rows/Columns is ideal when you
                         need things to visually line up, e.g. a label
                         column next to a control column. -->
                    <Expander Header="Signal Parameters (Grid)" IsExpanded="True">
                        <!-- NOTE: Avalonia's Grid has no RowSpacing/ColumnSpacing
                             property (unlike WinUI). Spacing between rows is
                             done here via a bottom Margin on each cell instead. -->
                        <Grid Margin="4"
                              ColumnDefinitions="Auto, *"
                              RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto">

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Frequency" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <Slider x:Name="FrequencySlider" Grid.Row="0" Grid.Column="1"
                                    Minimum="0.1" Maximum="5" Value="1" TickFrequency="0.1"
                                    Margin="0,0,0,8"
                                    ValueChanged="OnParameterChanged"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Amplitude" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <Slider x:Name="AmplitudeSlider" Grid.Row="1" Grid.Column="1"
                                    Minimum="0.1" Maximum="3" Value="1" TickFrequency="0.1"
                                    Margin="0,0,0,8"
                                    ValueChanged="OnParameterChanged"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Noise" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <Slider x:Name="NoiseSlider" Grid.Row="2" Grid.Column="1"
                                    Minimum="0" Maximum="1" Value="0.05" TickFrequency="0.01"
                                    Margin="0,0,0,8"
                                    ValueChanged="OnParameterChanged"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Point count" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <Slider x:Name="PointCountSlider" Grid.Row="3" Grid.Column="1"
                                    Minimum="10" Maximum="1000" Value="200"
                                    Margin="0,0,0,8"
                                    ValueChanged="OnParameterChanged"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Line width" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <Slider x:Name="LineWidthSlider" Grid.Row="4" Grid.Column="1"
                                    Minimum="1" Maximum="8" Value="2"
                                    Margin="0,0,0,8"
                                    ValueChanged="OnParameterChanged"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Current freq." VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="FrequencyValueText" Text="1.00" VerticalAlignment="Center"/>
                        </Grid>
                    </Expander>

                    <!-- (c) WrapPanel layout example.
                         WrapPanel flows children left-to-right and wraps
                         to the next line when it runs out of room,
                         handy for a row/cluster of action buttons. -->
                    <Expander Header="Actions (WrapPanel)" IsExpanded="True">
                        <WrapPanel Margin="4">
                            <Button Content="Plot" Click="OnPlotClick" Width="80" Margin="0,0,8,8"/>
                            <Button Content="Randomize" Click="OnRandomizeClick" Width="90" Margin="0,0,8,8"/>
                            <Button Content="Clear" Click="OnClearClick" Width="80" Margin="0,0,8,8"/>
                            <Button Content="Export PNG" Click="OnExportClick" Width="100" Margin="0,0,8,8"/>
                        </WrapPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>

            <!-- Draggable splitter between settings and chart -->
            <GridSplitter x:Name="SettingsSplitter" Grid.Column="1" Width="4" ResizeDirection="Columns"/>

            <!-- RIGHT COLUMN: the main "frame" - a bordered container
                 that holds the chart. Using a Border here to
                 visually separate the "frame" from the rest of the window,
                 and DockPanel inside to allow a header/status area plus
                 the chart filling remaining space. -->
            <Border Grid.Column="2" Margin="10" BorderThickness="1" CornerRadius="6">
                <DockPanel LastChildFill="True">

                    <!-- simple header/status strip for the chart frame -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,10,10,0" Spacing="10">
                        <TextBlock Text="Chart" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="StatusText" Text="Ready" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- The actual plot control, fills remaining space -->
                    <ContentControl x:Name="PlotContainer" Margin="10"/>

                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
