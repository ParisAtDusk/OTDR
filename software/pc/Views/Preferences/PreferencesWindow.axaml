<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OTDR.Views.ViewModels"
        x:DataType="vm:PreferencesWindowViewModel"
        x:Class="OTDR.Views.Preferences.PreferencesWindow"
        Title="Preferences"
        Width="420" Height="350"
        MinWidth="350" MinHeight="300"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="20">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Settings"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SemiColorText0}"/>
        </StackPanel>

        <!-- Footer -->
        <Button DockPanel.Dock="Bottom"
                Content="Close"
                HorizontalAlignment="Right"
                Margin="0,20,0,0"
                Padding="18,8"
                Theme="{StaticResource SolidButton}"
                Classes="Primary"
                Click="OnCloseClick"/>

        <!-- Settings cards -->
         <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">

                <Border Classes="Shadow"
                        Background="{DynamicResource SemiColorFill1}"
                        CornerRadius="8"
                        Padding="16,12">
                    <Grid ColumnDefinitions="8*,5*">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Plot Backend"
                                    FontSize="13"/>
                            <TextBlock Text="Requires restart"
                                    FontSize="11"
                                    Foreground="{DynamicResource SemiColorText2}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Right"
                            CornerRadius="6"
                            ItemsSource="{Binding PlottingBackends}"
                            SelectedItem="{Binding SelectedPlottingBackend}" />
                    </Grid>
                </Border>

                <Border Classes="Shadow"
                        Background="{DynamicResource SemiColorFill1}"
                        CornerRadius="8"
                        Padding="16,12">
                    <Grid ColumnDefinitions="8*,5*">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Theme"
                                    FontSize="13"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Right"
                            CornerRadius="6"
                            ItemsSource="{Binding AvailableThemes}"
                            SelectedItem="{Binding SelectedTheme}" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
