<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OTDR.Views.About.AboutWindow"
        Title="About OTDR App"
        Width="400"
        Height="300"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20"
          RowDefinitions="*,Auto">

        <TextBlock Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="400">
            <Run Text="Made by Krzysztof Paryż &amp; Kamil Skałka"/>
            <LineBreak/>
            <Run Text="AGH UST 2026/27"/>
        </TextBlock>

        <Button Grid.Row="1"
                Content="Close"
                Click="OnCloseClick"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"/>
    </Grid>

</Window>