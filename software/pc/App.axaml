<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:semi="https://irihi.tech/semi"
             x:Class="OTDR.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <semi:SemiTheme />
    </Application.Styles>
    <Application.Resources>
    <ResourceDictionary>
        <ResourceDictionary.ThemeDictionaries>

            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="StatusConnectedBrush" Color="#2E7D32"/>
                <SolidColorBrush x:Key="StatusBusyBrush" Color="#F9A825"/>
                <SolidColorBrush x:Key="StatusDisconnectedBrush" Color="#C62828"/>
            </ResourceDictionary>

            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="StatusConnectedBrush" Color="#66BB6A"/>
                <SolidColorBrush x:Key="StatusBusyBrush" Color="#FFCA28"/>
                <SolidColorBrush x:Key="StatusDisconnectedBrush" Color="#EF5350"/>
            </ResourceDictionary>

        </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
</Application.Resources>
</Application>